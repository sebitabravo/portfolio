---
import { cn } from "@/lib/utils"

interface Props {
  src?: string
  alt?: string
  fallback: string
  size?: "sm" | "md" | "lg" | "xl"
  class?: string
}

const {
  src,
  alt = "Avatar",
  fallback,
  size = "md",
  class: className,
} = Astro.props

const sizeClasses = {
  sm: "size-10 text-sm",
  md: "size-14 text-base",
  lg: "size-16 text-lg",
  xl: "size-64 text-6xl",
}
---

<div class={cn("relative overflow-hidden rounded-full border border-border bg-muted", sizeClasses[size], className)} data-avatar>
  {src && (
    <img
      src={src}
      alt={alt}
      loading="lazy"
      class="h-full w-full object-cover"
      data-avatar-image
    />
  )}
  <span
    class={cn(
      "absolute inset-0 flex items-center justify-center font-semibold text-muted-foreground",
      src && "hidden",
    )}
    data-avatar-fallback
    aria-hidden={src ? "true" : "false"}
  >
    {fallback}
  </span>
</div>

<script>
  if (!window.__portfolioAvatarBound) {
    window.__portfolioAvatarBound = true

    document.addEventListener("error", (event) => {
      const target = event.target
      if (!(target instanceof HTMLImageElement)) return
      if (!target.hasAttribute("data-avatar-image")) return

      target.classList.add("hidden")

      const wrapper = target.closest("[data-avatar]")
      const fallback = wrapper?.querySelector("[data-avatar-fallback]")
      if (fallback instanceof HTMLElement) {
        fallback.classList.remove("hidden")
        fallback.setAttribute("aria-hidden", "false")
      }
    }, true)
  }
</script>
