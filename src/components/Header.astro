---
// Header Component - Navigation (Superhuman-inspired)
import { getTranslations, type Locale } from "@/lib/i18n"
import ThemeToggle from "./ThemeToggle.astro"
import LanguageToggle from "./LanguageToggle.astro"
import DropdownMenu from "./ui/DropdownMenu.astro"

interface Props {
  locale?: Locale
}

const { locale = 'es' } = Astro.props
const t = getTranslations(locale)
const prefix = locale === 'es' ? '' : '/en'

const sectionIds = {
  es: { experience: 'experiencia', projects: 'proyectos', education: 'educacion', certifications: 'certificaciones', about: 'sobre-mi', contact: 'contacto' },
  en: { experience: 'experience', projects: 'projects', education: 'education', certifications: 'certifications', about: 'about', contact: 'contact' },
} as const

const ids = sectionIds[locale]
const mobileMenuId = `mobile-nav-${locale}`

const navItems = [
  { title: t.nav.projects, label: ids.projects, url: `${prefix}#${ids.projects}` },
  { title: t.nav.experience, label: ids.experience, url: `${prefix}#${ids.experience}` },
  { title: t.nav.education, label: ids.education, url: `${prefix}#${ids.education}` },
  { title: t.nav.certifications, label: ids.certifications, url: `${prefix}#${ids.certifications}` },
  { title: t.nav.about, label: ids.about, url: `${prefix}#${ids.about}` },
  { title: t.nav.contact, label: ids.contact, url: `${prefix}#${ids.contact}` },
]
---

<header class="fixed inset-x-0 top-0 z-50">
  <div class="mx-auto max-w-[1200px] px-4">
    <nav
      aria-label={locale === 'es' ? 'Navegación principal' : 'Main navigation'}
      class="site-nav mx-auto flex h-14 items-center justify-between gap-6 px-4 text-sm font-medium transition-colors duration-300"
    >
      <div class="flex items-center gap-4">
        <a href={prefix || '/'} class="text-base font-semibold tracking-tight">Sebastian Bravo</a>
      </div>

      <div class="hidden md:flex items-center gap-1">
        {navItems.map((link) => (
          <a
            class="nav-link relative px-3 py-2 rounded-[8px] transition-colors duration-150"
            aria-label={link.label}
            href={link.url}
          >
            {link.title}
          </a>
        ))}
      </div>

      <div class="flex items-center gap-3">
        <div class="flex items-center gap-2 border-l border-transparent pl-3">
          <ThemeToggle />
          <LanguageToggle />
        </div>

        <div class="md:hidden">
          <DropdownMenu id={mobileMenuId} triggerLabel={t.nav.menu}>
            <div class="flex flex-col gap-1 p-2">
              {navItems.map((link) => (
                <a
                  href={link.url}
                  aria-label={link.label}
                  class="rounded-[8px] px-3 py-2 text-sm text-foreground/90 transition-colors hover:bg-muted/50"
                  role="menuitem"
                >
                  {link.title}
                </a>
              ))}
            </div>
          </DropdownMenu>
        </div>
      </div>
    </nav>
  </div>
</header>

<script>
  document.addEventListener("astro:page-load", () => {
    const sections = Array.from(document.querySelectorAll("section[id]"))
    const navLinks = Array.from(document.querySelectorAll(".site-nav .nav-link"))
    const siteNav = document.querySelector('.site-nav')

    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            navLinks.forEach((link) => {
              const aria = link.getAttribute('aria-label')
              if (aria === entry.target.id) link.classList.add('nav-active')
              else link.classList.remove('nav-active')
            })
          }
        })
      },
      { threshold: 0.35 }
    )

    sections.forEach((s) => io.observe(s))

    const onScroll = () => {
      if (!siteNav) return
      if (window.scrollY > 40) siteNav.classList.add('scrolled')
      else siteNav.classList.remove('scrolled')
    }

    onScroll()
    window.addEventListener('scroll', onScroll, { passive: true })

    document.addEventListener('visibilitychange', () => {
      if (document.visibilityState === 'hidden') {
        io.disconnect()
      } else {
        sections.forEach((s) => io.observe(s))
      }
    })
  })
</script>

<style>
  .nav-link {
    color: inherit;
  }

  .nav-link.nav-active::after {
    content: '';
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    bottom: -6px;
    width: 36%;
    height: 3px;
    border-radius: 8px;
    background: hsl(var(--primary));
    box-shadow: 0 4px 18px hsl(var(--primary) / 0.35);
  }

  /* Default: semi-transparent nav with blur */
  .site-nav {
    background: rgba(248, 248, 252, 0.72);
    border-bottom: 1px solid hsl(var(--parchment) / 0.5);
    color: hsl(var(--foreground));
    backdrop-filter: saturate(1.25) blur(12px);
    -webkit-backdrop-filter: saturate(1.25) blur(12px);
  }

  :global(.dark) .site-nav {
    background: rgba(15, 15, 20, 0.72);
    border-bottom: 1px solid rgba(42, 42, 53, 0.4);
    color: rgba(255, 255, 255, 0.9);
  }

  .site-nav .nav-link:hover {
    background: hsl(var(--muted));
  }

  :global(.dark) .site-nav .nav-link:hover {
    background: rgba(255, 255, 255, 0.08);
  }

  /* Scrolled: more opaque background */
  .site-nav.scrolled {
    background: rgba(248, 248, 252, 0.96);
    border-bottom: 1px solid hsl(var(--border));
    color: hsl(var(--foreground));
  }

  .site-nav.scrolled .nav-link:hover {
    background: hsl(var(--muted));
  }

  .site-nav.scrolled :global(#theme-toggle),
  .site-nav.scrolled :global(#language-toggle) {
    color: hsl(var(--foreground));
  }

  .site-nav.scrolled :global(#theme-toggle:hover),
  .site-nav.scrolled :global(#language-toggle:hover) {
    background: hsl(var(--muted));
  }

  /* Dark scrolled */
  :global(.dark) .site-nav.scrolled {
    background: rgba(15, 15, 20, 0.92);
    border-bottom: 1px solid rgba(42, 42, 53, 0.7);
    color: hsl(var(--foreground));
  }

  :global(.dark) .site-nav.scrolled .nav-link:hover {
    background: rgba(255, 255, 255, 0.06);
  }

  .dropdown:focus {
    outline: none;
  }
</style>
