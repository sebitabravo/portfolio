---
import Button from "@/components/ui/Button.astro"
import Toast from "@/components/ui/Toast.astro"
import { personalInfo } from "@/lib/data"
import { getTranslations, type Locale } from "@/lib/i18n"

interface Props {
  locale?: Locale
}

const { locale = "es" } = Astro.props
const t = getTranslations(locale)

const formId = `contact-form-${locale}`
const toastId = `contact-toast-${locale}`
const endpoint = `https://formsubmit.co/ajax/${personalInfo.email}`
---

<div class="rounded-2xl border border-border bg-card/70 p-6 shadow-sm md:p-8">
  <p class="mb-6 text-sm text-muted-foreground">{t.contactForm.subtitle}</p>

  <form
    id={formId}
    class="space-y-4"
    novalidate
    data-contact-form
    data-contact-endpoint={endpoint}
    data-contact-toast={toastId}
    data-success-message={t.contactForm.successMessage}
    data-error-message={t.contactForm.errorMessage}
    data-sending-message={t.contactForm.sendingMessage}
  >
    <input type="hidden" name="_subject" value={`Portfolio Contact (${locale.toUpperCase()})`} />
    <input type="hidden" name="_captcha" value="false" />
    <input type="hidden" name="_template" value="table" />
    <input type="text" name="_honey" class="hidden" tabindex="-1" autocomplete="off" />

    <div class="grid gap-4 md:grid-cols-2">
      <label class="space-y-2 text-sm font-medium text-foreground" for={`${formId}-name`}>
        {t.contactForm.nameLabel}
        <input
          id={`${formId}-name`}
          name="name"
          required
          minlength="2"
          autocomplete="name"
          class="w-full rounded-md border border-input bg-background px-3 py-2 text-sm text-foreground shadow-sm outline-none transition focus:border-primary focus:ring-1 focus:ring-primary"
          placeholder={t.contactForm.namePlaceholder}
        />
      </label>

      <label class="space-y-2 text-sm font-medium text-foreground" for={`${formId}-email`}>
        {t.contactForm.emailLabel}
        <input
          id={`${formId}-email`}
          type="email"
          name="email"
          required
          autocomplete="email"
          class="w-full rounded-md border border-input bg-background px-3 py-2 text-sm text-foreground shadow-sm outline-none transition focus:border-primary focus:ring-1 focus:ring-primary"
          placeholder={t.contactForm.emailPlaceholder}
        />
      </label>
    </div>

    <label class="space-y-2 text-sm font-medium text-foreground" for={`${formId}-message`}>
      {t.contactForm.messageLabel}
      <textarea
        id={`${formId}-message`}
        name="message"
        required
        minlength="10"
        rows={6}
        class="w-full rounded-md border border-input bg-background px-3 py-2 text-sm text-foreground shadow-sm outline-none transition focus:border-primary focus:ring-1 focus:ring-primary"
        placeholder={t.contactForm.messagePlaceholder}
      ></textarea>
    </label>

    <div class="flex flex-wrap items-center justify-between gap-3">
      <Button type="submit" size="md" data-contact-submit>{t.contactForm.submit}</Button>
      <p class="text-xs text-muted-foreground">{t.contactForm.privacyNote}</p>
    </div>

    <p class="hidden text-sm font-medium" data-contact-feedback aria-live="polite"></p>
  </form>

  <Toast id={toastId} />
</div>

<script>
  import { trackEvent } from "@/lib/analytics"

  const initializeContactForms = () => {
    const forms = document.querySelectorAll("[data-contact-form]")

    forms.forEach((formElement) => {
      if (!(formElement instanceof HTMLFormElement)) return
      if (formElement.dataset.bound === "true") return

      formElement.dataset.bound = "true"

      const endpoint = formElement.dataset.contactEndpoint || ""
      const toastId = formElement.dataset.contactToast || ""
      const successMessage = formElement.dataset.successMessage || ""
      const errorMessage = formElement.dataset.errorMessage || ""
      const sendingMessage = formElement.dataset.sendingMessage || ""

      const submitButton = formElement.querySelector("[data-contact-submit]")
      const feedback = formElement.querySelector("[data-contact-feedback]")

      if (submitButton instanceof HTMLButtonElement && !submitButton.dataset.defaultLabel) {
        submitButton.dataset.defaultLabel = submitButton.textContent || ""
      }

      const showFeedback = (message: string, type: "error" | "success") => {
        if (feedback instanceof HTMLElement) {
          feedback.textContent = message
          feedback.classList.remove("hidden", "text-emerald-600", "text-red-600")
          feedback.classList.add(type === "error" ? "text-red-600" : "text-emerald-600")
        }

        const toast = window.portfolioToast
        if (toast && typeof toast.show === "function") {
          toast.show(toastId, message, type)
        }
      }

      formElement.addEventListener("submit", async (event) => {
        event.preventDefault()

        if (!formElement.reportValidity()) return

        if (submitButton instanceof HTMLButtonElement) {
          submitButton.disabled = true
          submitButton.textContent = sendingMessage
        }

        try {
          const formData = new FormData(formElement)

          const response = await fetch(endpoint, {
            method: "POST",
            headers: {
              Accept: "application/json",
            },
            body: formData,
          })

          if (!response.ok) {
            throw new Error(`HTTP ${response.status}`)
          }

          formElement.reset()
          showFeedback(successMessage, "success")
          trackEvent({ name: "contact_submit", props: { status: "success" } })
        } catch {
          showFeedback(errorMessage, "error")
          trackEvent({ name: "contact_submit", props: { status: "error" } })
        } finally {
          if (submitButton instanceof HTMLButtonElement) {
            submitButton.disabled = false
            submitButton.textContent = submitButton.dataset.defaultLabel || ""
          }
        }
      })
    })
  }

  document.addEventListener("astro:page-load", initializeContactForms)
  initializeContactForms()
</script>
