---
import { getProjects } from "@/lib/data"
import { getTranslations, type Locale } from "@/lib/i18n"
import { getTechStyle } from "@/lib/tech-colors"
import { getTechIcon } from "@/lib/tech-icons-map"
import GitHubIcon from "./icons/GitHub.astro"
import LinkIcon from "./icons/Link.astro"
import Dialog from "./ui/Dialog.astro"

interface Props {
  locale?: Locale
}

const { locale = "es" } = Astro.props
const t = getTranslations(locale)

const projects = getProjects(locale)
  .slice()
  .sort((projectA, projectB) => projectA.order - projectB.order)

const statusLabels: Record<string, Record<string, string>> = {
  es: { production: "En producción", development: "En desarrollo", demo: "Demo" },
  en: { production: "In production", development: "In development", demo: "Demo" },
}

const statusColors: Record<string, string> = {
  production: "bg-emerald-500/10 text-emerald-600 dark:text-emerald-400 border-emerald-500/20",
  development: "bg-amber-500/10 text-amber-600 dark:text-amber-400 border-amber-500/20",
  demo: "bg-sky-500/10 text-sky-600 dark:text-sky-400 border-sky-500/20",
}

const visualGradients: Record<string, string> = {
  manttoai: "linear-gradient(140deg, #0e5f66 0%, #3d9f7a 100%)",
  vulcania: "linear-gradient(140deg, #7a2a0a 0%, #e35b25 45%, #f3aa3a 100%)",
  "rapido-sur": "linear-gradient(140deg, #1e3a8a 0%, #3730a3 50%, #6d28d9 100%)",
  banking: "linear-gradient(140deg, #1e3a5f 0%, #2563eb 50%, #0ea5e9 100%)",
}

---

<div class="space-y-12">
  <div class="grid gap-6 sm:gap-8 md:grid-cols-2" data-projects-list>
    {projects.map(({ slug, title, description, fullDescription, tags, liveUrl, githubUrl, featured, status, metrics }, i) => {
      const dialogId = `project-details-${locale}-${slug}`
      const statusLabel = status ? statusLabels[locale]?.[status] : undefined
      const statusColor = status ? statusColors[status] : ""
      const gradient = visualGradients[slug] ?? "linear-gradient(140deg, #2b2b2b 0%, #5a5a5a 100%)"

      return (
        <article
          data-animate
          data-animate-delay={String((i % 4) + 1)}
          class="group flex h-full flex-col overflow-hidden rounded-2xl border border-[hsl(var(--parchment))] bg-[hsl(var(--card))] transition-all duration-300 hover:-translate-y-[2px] hover:shadow-[var(--shadow-card-hover)]"
          data-project-card
          data-project={slug}
          data-project-tags={tags.join(",")}
        >
          <div class="relative overflow-hidden border-b border-[hsl(var(--parchment))]">
            <div class="relative h-48 w-full sm:h-56 lg:h-64" style={`background:${gradient};`}>
              <div class="absolute inset-0 bg-black/15"></div>
              <div class="absolute inset-x-0 bottom-0 p-3 sm:p-4 lg:p-5">
                {statusLabel && (
                  <span class:list={["inline-block rounded-md border px-2 py-0.5 text-[10px] font-mono uppercase tracking-[0.14em] mb-1.5", statusColor]}>
                    {statusLabel}
                  </span>
                )}
                <h4 class="mt-1 font-mono text-lg font-semibold text-white sm:text-xl lg:text-2xl">{title}</h4>
              </div>
            </div>
          </div>

          <div class="flex grow flex-col p-4 sm:p-5 lg:p-6">
            <div class="flex flex-wrap items-start justify-between gap-2">
              <h3 class="text-lg font-semibold text-foreground sm:text-xl">{title}</h3>
              {featured && (
                <span class="rounded-lg border border-[hsl(var(--primary))]/60 bg-[hsl(var(--primary))]/15 px-2.5 py-1 text-[11px] font-medium uppercase tracking-[0.08em] text-[hsl(var(--primary-foreground))] dark:text-[hsl(var(--primary))]">
                  {t.projects.featured}
                </span>
              )}
            </div>

            <p class="mt-3 text-sm leading-[1.60] text-foreground/75 sm:text-base">{description}</p>

            {metrics && metrics.length > 0 && (
              <div class="mt-3 flex flex-wrap gap-3">
                {metrics.map((m) => (
                  <div class="flex items-baseline gap-1.5">
                    <span class="text-xs text-[hsl(var(--caption-color))]">{m.label}</span>
                    <span class="text-sm font-semibold text-foreground">{m.value}</span>
                  </div>
                ))}
              </div>
            )}

            <div class="mt-4 flex flex-wrap gap-2">
              {tags.map((tag) => {
                const style = getTechStyle(tag)
                const Icon = getTechIcon(tag)

                return (
                  <span class:list={["tech-badge flex items-center gap-1.5", style.bg, style.border, style.text]}>
                    {Icon && <Icon class="size-3 sm:size-4" />}
                    {tag}
                  </span>
                )
              })}
            </div>

            <footer class="mt-5 flex flex-wrap items-center gap-2 sm:mt-6">
              {githubUrl && (
                <a
                  href={githubUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  data-track-project={slug}
                  data-track-action="code"
                  class="inline-flex h-9 sm:h-10 items-center gap-1.5 sm:gap-2 rounded-lg border border-[hsl(var(--parchment))] bg-transparent px-3 sm:px-3.5 text-sm font-medium text-foreground/85 transition hover:bg-[hsl(var(--muted))]"
                >
                  <GitHubIcon class="size-3 sm:size-4" />
                  {t.projects.viewCode}
                </a>
              )}

              {liveUrl && (
                <a
                  href={liveUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  data-track-project={slug}
                  data-track-action="live"
                  class="btn-cream !h-9 sm:!h-10 !px-3 sm:!px-3.5 !text-sm"
                >
                  <LinkIcon class="size-3 sm:size-4" />
                  {t.projects.viewProject}
                </a>
              )}

              <Dialog
                id={dialogId}
                title={title}
                description={description}
                triggerText={t.projects.viewDetails}
                closeText={t.common.close}
                class="rounded-lg border border-[hsl(var(--parchment))] bg-transparent px-3 sm:px-3.5 py-2 text-sm font-medium text-foreground/85 shadow-none hover:bg-[hsl(var(--muted))]"
              >
                <p class="whitespace-pre-wrap text-sm text-foreground/85 sm:text-base">{fullDescription}</p>
              </Dialog>
            </footer>
          </div>
        </article>
      )
    })}
  </div>

  <div class="mt-4 flex justify-center">
    <a
      href="https://github.com/sebitabravo?tab=repositories"
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex h-11 items-center gap-2 rounded-lg border border-[hsl(var(--parchment))] bg-transparent px-4 text-sm font-medium text-foreground/85 transition hover:bg-[hsl(var(--muted))]"
    >
      <GitHubIcon class="size-5" />
      {t.projects.viewMoreGithub}
      <svg class="ml-1 size-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
      </svg>
    </a>
  </div>
</div>

<script>
  import { trackEvent } from "@/lib/analytics"

  const setupProjects = () => {
    const trackButtons = document.querySelectorAll<HTMLElement>("[data-track-project]")
    trackButtons.forEach((btn) => {
      if (btn.dataset.trackBound === "true") return
      btn.dataset.trackBound = "true"
      btn.addEventListener("click", () => {
        const project = btn.dataset.trackProject ?? ""
        const action = (btn.dataset.trackAction ?? "details") as "live" | "code" | "details"
        trackEvent({ name: "project_view", props: { project, action } })
      })
    })

    document.querySelectorAll<HTMLElement>("[data-dialog-trigger]").forEach((btn) => {
      if (btn.dataset.trackBound === "true") return
      btn.dataset.trackBound = "true"
      btn.addEventListener("click", () => {
        const card = btn.closest<HTMLElement>("[data-project]")
        const project = card?.dataset.project ?? ""
        trackEvent({ name: "project_view", props: { project, action: "details" } })
      })
    })
  }

  document.addEventListener("astro:page-load", setupProjects)
  setupProjects()
</script>
