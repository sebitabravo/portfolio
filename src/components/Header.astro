---
// Header Component - Navigation
import { getTranslations, type Locale } from "@/lib/i18n"
import ThemeToggle from "./ThemeToggle.astro"
import LanguageToggle from "./LanguageToggle.astro"
import DropdownMenu from "./ui/DropdownMenu.astro"

interface Props {
  locale?: Locale
}

const { locale = 'es' } = Astro.props
const t = getTranslations(locale)
const prefix = locale === 'es' ? '' : '/en'

const sectionIds = {
  es: { experience: 'experiencia', projects: 'proyectos', education: 'educacion', certifications: 'certificaciones', about: 'sobre-mi', contact: 'contacto' },
  en: { experience: 'experience', projects: 'projects', education: 'education', certifications: 'certifications', about: 'about', contact: 'contact' },
} as const

const ids = sectionIds[locale]
const mobileMenuId = `mobile-nav-${locale}`

// Orden alineado con la estructura de landing de conversión (#11)
const navItems = [
  { title: t.nav.projects, label: ids.projects, url: `${prefix}#${ids.projects}` },
  { title: t.nav.contact, label: ids.contact, url: `${prefix}#${ids.contact}` },
  { title: t.nav.experience, label: ids.experience, url: `${prefix}#${ids.experience}` },
  { title: t.nav.education, label: ids.education, url: `${prefix}#${ids.education}` },
  { title: t.nav.certifications, label: ids.certifications, url: `${prefix}#${ids.certifications}` },
  { title: t.nav.about, label: ids.about, url: `${prefix}#${ids.about}` },
]
---

<header
  class="fixed top-0 z-50 flex items-center justify-center w-full mx-auto mt-2"
>
  <nav
    aria-label={locale === 'es' ? 'Navegación principal' : 'Main navigation'}
    class="flex px-3 text-sm font-medium rounded-full text-foreground/80 justify-center items-center gap-x-1 glass"
  >
    <DropdownMenu id={mobileMenuId} triggerLabel={t.nav.menu} class="md:hidden">
      <div class="flex flex-col gap-1">
        {navItems.map((link) => (
          <a
            href={link.url}
            aria-label={link.label}
            class="rounded-md px-3 py-2 text-sm text-foreground/85 transition hover:bg-accent hover:text-accent-foreground"
            role="menuitem"
          >
            {link.title}
          </a>
        ))}
      </div>
    </DropdownMenu>

    {
      navItems.map((link) => (
        <a
          class="relative hidden md:block rounded-md px-3 py-2 transition hover:bg-accent hover:text-accent-foreground"
          aria-label={link.label}
          href={link.url}
        >
          {link.title}
        </a>
      ))
    }

    <div class="flex items-center gap-1 border-l border-border/50 pl-2 md:ml-2">
      <ThemeToggle />
      <LanguageToggle />
    </div>
  </nav>
</header>

<script>
  document.addEventListener("astro:page-load", () => {
    const sections = document.querySelectorAll("section")
    const navItems = document.querySelectorAll("header nav a")

    const callback = (entries: any[]) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          navItems.forEach((item) => {
            if (item.getAttribute("aria-label") == entry.target.id) {
              item.classList.add("nav-active")
            } else {
              item.classList.remove("nav-active")
            }
          })
        }
      })
    }

    const observer = new IntersectionObserver(callback, {
      root: null,
      rootMargin: "0px",
      threshold: 0.3,
    })

    sections.forEach((section) => {
      observer.observe(section)
    })

    // Cleanup function
    document.onvisibilitychange = () => {
      if (document.visibilityState === "hidden") {
        observer.disconnect()
      } else {
        sections.forEach((section) => {
          observer.observe(section)
        })
      }
    }
  })
</script>

<style>
  /* Estado activo del ítem de nav — contraste WCAG AA en ambos modos */
  .nav-active {
    color: #92400e; /* yellow-800: ratio ~7:1 sobre fondo claro */
  }

  :global(.dark) .nav-active {
    color: #fde047; /* yellow-300: ratio ~9:1 sobre fondo oscuro */
  }

  nav {
    animation: nav-shadown 1s linear both;
    animation-timeline: scroll();
    animation-range: 0 100px;
    background-color: transparent;
  }

  @keyframes nav-shadown {
    to {
      background-color: hsl(var(--card) / 0.8);
      box-shadow: 0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1);
      backdrop-filter: blur(8px);
      --tw-ring-offset-shadow: var(--tw-ring-inset) 0 0 0 var(--tw-ring-offset-width) var(--tw-ring-offset-color);
      --tw-ring-shadow: var(--tw-ring-inset) 0 0 0 calc(1px + var(--tw-ring-offset-width)) hsl(var(--border));
      box-shadow: var(--tw-ring-offset-shadow), var(--tw-ring-shadow), var(--tw-shadow, 0 0 #0000);
    }
  }
</style>
