---
// Education — Superhuman clean cards
import { getEducation } from "@/lib/data"
import { getTranslations, type Locale } from "@/lib/i18n"
import { formatDate } from "@/lib/utils"

interface Props {
  locale?: Locale
}

const { locale = 'es' } = Astro.props
const t = getTranslations(locale)
const education = getEducation(locale)
---

<div class="flex flex-col gap-6 mt-8">
  {education.map(({ institution, degree, description, startDate, endDate, current, location, grade, skills }, i) => (
    <article data-animate data-animate-delay={String(i + 1)} class="rounded-2xl border border-[hsl(var(--parchment))] bg-[hsl(var(--card))] p-6 transition-all duration-300 hover:-translate-y-[2px] hover:shadow-[var(--shadow-card-hover)]">
      <div class="flex flex-col sm:flex-row sm:justify-between sm:items-start gap-3">
        <div>
          <h3 class="font-semibold text-foreground">{degree}</h3>
          <p class="text-sm text-[hsl(var(--caption-color))] mt-0.5">{institution}</p>
        </div>
        <div class="text-xs text-[hsl(var(--caption-color))] text-right shrink-0">
          <time>{formatDate(startDate, locale)}</time>
          <span> — </span>
          <time>{current ? t.education.present : endDate ? formatDate(endDate, locale) : ""}</time>
          {location && <p class="mt-0.5">{location}</p>}
          {grade && <p class="mt-0.5 font-medium text-foreground/70">{t.education.grade}: {grade}</p>}
        </div>
      </div>

      {description && (
        <p class="mt-4 text-sm leading-[1.60] text-foreground/70">{description}</p>
      )}

      {skills && skills.length > 0 && (
        <div class="flex flex-wrap gap-2 mt-4">
          {skills.map((skill) => (
            <span class="tech-badge">{skill}</span>
          ))}
        </div>
      )}
    </article>
  ))}
</div>
