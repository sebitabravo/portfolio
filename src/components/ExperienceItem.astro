---
// Experience Item — Superhuman clean timeline with lavender accent
import { formatDate } from "@/lib/utils"
import { getTranslations, type Locale } from "@/lib/i18n"
import type { ExperienceLogo } from "@/lib/data"

interface Props {
  company: string
  position: string
  description: string
  startDate: Date
  endDate?: Date | null
  current: boolean
  location?: string
  skills: string[]
  logos?: ExperienceLogo[]
  url?: string
  locale?: Locale
  index?: number
}

const { company, position, description, startDate, endDate, current, location, skills, logos, url, locale = 'es', index = 0 } = Astro.props
const t = getTranslations(locale)

const dateText = current
  ? t.work.currently
  : endDate
    ? formatDate(endDate, locale)
    : formatDate(startDate, locale)
---

<div data-animate data-animate-delay={String(index + 1)} class="relative pl-8 pb-8 before:absolute before:left-0 before:block before:h-full before:border-l before:border-[hsl(var(--parchment))] before:content-['']">
  <!-- Timeline dot — Lavender glow -->
  <span class="absolute -left-[5px] top-1 size-[10px] rounded-full bg-[hsl(var(--primary))] ring-4 ring-[hsl(var(--background))]"></span>

  <div class="rounded-2xl border border-[hsl(var(--parchment))] bg-[hsl(var(--card))] p-6">
    <div class="grid md:grid-cols-5 md:gap-8">
      <!-- Meta info -->
      <div class="md:col-span-2 mb-4 md:mb-0">
        <h3 class="font-semibold text-foreground leading-snug">{position}</h3>
        <h4 class="text-sm text-[hsl(var(--caption-color))] mt-0.5">{company}</h4>
        <time class="text-xs text-[hsl(var(--caption-color))] mt-2 block">{dateText}</time>
        {location && <p class="text-xs text-[hsl(var(--caption-color))]">{location}</p>}

        {logos && logos.length > 0 && (
          <div class="flex flex-wrap items-center gap-3 mt-4">
            {logos.map((logo) => (
              <a
                href={logo.url}
                target="_blank"
                rel="noopener noreferrer"
                title={logo.alt}
                aria-label={logo.alt}
                class="group flex size-14 items-center justify-center rounded-lg border border-[hsl(var(--parchment))] bg-[hsl(var(--card))] p-2 transition-opacity duration-200 hover:opacity-100 opacity-75"
              >
                <img
                  src={logo.src}
                  alt={logo.alt}
                  width={48}
                  height={48}
                  loading="lazy"
                  decoding="async"
                  class="size-full object-contain"
                />
              </a>
            ))}
          </div>
        )}
      </div>

      <!-- Description -->
      <div class="flex flex-col gap-2 text-foreground/70 md:col-span-3">
        <p class="text-sm leading-[1.60]">{description}</p>

        {skills.length > 0 && (
          <div class="flex flex-wrap gap-2 mt-2">
            {skills.map((skill) => (
              <span class="tech-badge">{skill}</span>
            ))}
          </div>
        )}

        {url && (
          <a
            href={url}
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-1 text-sm text-[hsl(var(--accent))] hover:underline mt-2 focus-ring rounded px-1"
          >
            {t.work.viewMore}
            <svg class="size-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
        )}
      </div>
    </div>
  </div>
</div>
