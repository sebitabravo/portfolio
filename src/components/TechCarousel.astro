---
/**
 * TechCarousel — Dashboard rotativo de stack tecnológico
 *
 * Muestra grupos de tecnologías con rotación automática,
 * dots indicadores, pausa en hover y navegación con teclado.
 */

import { technologies } from '@/data/technologies'
import { techIconsMap } from '@/lib/tech-icons-map'

// Group techs into pages (6-7 per page, 4 pages total)
const itemsPerPage = 6
const totalPages = Math.ceil(technologies.length / itemsPerPage)
const pages: Array<Array<typeof technologies[number]>> = []
for (let i = 0; i < technologies.length; i += itemsPerPage) {
  pages.push(technologies.slice(i, i + itemsPerPage))
}
---

<div class="stack-dashboard" id="stack-dashboard" role="region" aria-label="Stack tecnológico" aria-roledescription="carousel">
  <div class="stack-viewport" id="stack-viewport">
    {pages.map((page, pageIndex) => (
      <div
        class="stack-page"
        data-page={pageIndex}
        aria-hidden={pageIndex !== 0 ? "true" : undefined}
      >
        {page.map((tech) => {
          const IconComponent = techIconsMap[tech.name as keyof typeof techIconsMap]

          return (
            <div class="tech-item">
              <span class="tech-icon">
                {IconComponent ? (
                  <IconComponent class="w-10 h-10" />
                ) : (
                  <span class="text-4xl">{tech.icon}</span>
                )}
              </span>
              <span class="tech-name">{tech.name}</span>
            </div>
          )
        })}
      </div>
    ))}
  </div>

  <!-- Dots -->
  <div class="stack-dots" aria-label="Navegación de páginas" id="stack-dots">
    {pages.map((_, i) => (
      <button
        type="button"
        class="stack-dot"
        data-dot={i}
        aria-label={`Página ${i + 1} de ${pages.length}`}
        aria-current={i === 0 ? "true" : undefined}
      >
      </button>
    ))}
  </div>
</div>

<script>
  function initStackDashboard() {
    const dashboard = document.getElementById('stack-dashboard')
    const pages = Array.from(document.querySelectorAll('.stack-page'))
    const dots = Array.from(document.querySelectorAll('.stack-dot'))
    const viewport = document.getElementById('stack-viewport')

    if (!dashboard || pages.length === 0 || !viewport) return

    let current = 0
    let timer: ReturnType<typeof setInterval> | null = null
    const interval = 4000

    function showPage(index: number) {
      const prev = current
      pages.forEach((p) => {
        p.classList.remove('stack-page-active', 'stack-page-enter', 'stack-page-exit')
        p.setAttribute('aria-hidden', 'true')
      })

      // Animate exit for previous
      pages[prev]?.classList.add('stack-page-exit')

      // Animate enter for new
      pages[index].classList.add('stack-page-active', 'stack-page-enter')
      pages[index].setAttribute('aria-hidden', 'false')

      dots.forEach((d, i) => {
        d.classList.toggle('active', i === index)
        d.setAttribute('aria-current', i === index ? 'true' : 'false')
      })

      current = index
    }

    function nextPage() {
      showPage((current + 1) % pages.length)
    }

    function prevPage() {
      showPage((current - 1 + pages.length) % pages.length)
    }

    function startTimer() {
      stopTimer()
      timer = setInterval(nextPage, interval)
    }

    function stopTimer() {
      if (timer) {
        clearInterval(timer)
        timer = null
      }
    }

    // Hover: pause
    dashboard.addEventListener('mouseenter', stopTimer)
    dashboard.addEventListener('mouseleave', startTimer)

    // Keyboard nav
    document.addEventListener('keydown', (e) => {
      if (!dashboard.matches(':hover')) return
      if (e.key === 'ArrowRight') { e.preventDefault(); nextPage() }
      if (e.key === 'ArrowLeft') { e.preventDefault(); prevPage() }
    })

    // Dot clicks
    dots.forEach((dot) => {
      dot.addEventListener('click', () => {
        const idx = parseInt(dot.dataset.dot ?? '0', 10)
        showPage(idx)
        // Restart timer after manual interaction
        startTimer()
      })
    })

    // Start
    startTimer()
  }

  document.addEventListener('DOMContentLoaded', initStackDashboard)
  document.addEventListener('astro:page-load', initStackDashboard)
</script>

<style>
  .stack-dashboard {
    width: 100%;
    position: relative;
  }

  .stack-viewport {
    position: relative;
    min-height: 120px;
  }

  /* Each page is a grid of items */
  .stack-page {
    display: none;
    grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
    gap: 0.75rem;
    opacity: 0;
    transform: translateX(12px);
  }

  .stack-page-active {
    display: grid;
  }

  .stack-page-enter {
    animation: stackEnter 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .stack-page-exit {
    display: grid;
    position: absolute;
    inset: 0;
    animation: stackExit 0.3s ease forwards;
  }

  @keyframes stackEnter {
    from { opacity: 0; transform: translateX(12px); }
    to   { opacity: 1; transform: translateX(0); }
  }

  @keyframes stackExit {
    from { opacity: 1; transform: translateX(0); }
    to   { opacity: 0; transform: translateX(-12px); }
  }

  /* Tech items */
  .tech-item {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 0.5rem;
    min-width: max-content;
    padding: 0.5rem 0.75rem;
    background: hsl(var(--card));
    border: 1px solid hsl(var(--parchment));
    border-radius: 0.5rem;
    transition: all 0.3s ease;
  }

  .tech-item:hover {
    transform: translateY(-2px);
    border-color: hsl(var(--primary) / 0.5);
    box-shadow: var(--shadow-card);
  }

  .tech-icon {
    font-size: 1.15rem;
    transition: transform 0.2s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1.5rem;
    height: 1.5rem;
    color: hsl(var(--muted-foreground));
  }

  .tech-item:hover .tech-icon {
    transform: scale(1.06);
    color: hsl(var(--foreground));
  }

  .tech-name {
    font-family: 'JetBrains Mono Variable', 'JetBrains Mono', monospace;
    font-size: 0.75rem;
    font-weight: 500;
    color: hsl(var(--muted-foreground));
  }

  /* Dots */
  .stack-dots {
    display: flex;
    gap: 6px;
    justify-content: center;
    margin-top: 16px;
  }

  .stack-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: hsl(var(--muted-foreground) / 0.35);
    border: none;
    cursor: pointer;
    padding: 0;
    transition: background 0.3s, width 0.3s;
  }

  .stack-dot:hover {
    background: hsl(var(--primary) / 0.5);
  }

  .stack-dot.active {
    background: hsl(var(--primary));
    width: 18px;
    border-radius: 3px;
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .stack-page {
      transform: none;
    }

    .stack-page-active {
      display: grid;
      opacity: 1;
      animation: none;
    }

    .stack-page-enter,
    .stack-page-exit {
      animation: none;
    }

    .stack-page-exit {
      display: none;
    }
  }

  /* Mobile */
  @media (max-width: 768px) {
    .stack-page {
      grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
      gap: 0.6rem;
    }

    .tech-item {
      padding: 0.45rem 0.65rem;
    }

    .tech-icon {
      font-size: 1rem;
      width: 1.25rem;
      height: 1.25rem;
    }

    .tech-name {
      font-size: 0.7rem;
    }
  }
</style>
