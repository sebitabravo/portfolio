---
// Footer Component (Superhuman-inspired)
import { personalInfo } from "@/lib/data"
import { getTranslations, type Locale } from "@/lib/i18n"

interface Props {
  locale?: Locale
}

const { locale = 'es' } = Astro.props
const t = getTranslations(locale)
const currentYear = new Date().getFullYear()
const aboutUrl = locale === 'es' ? '#sobre-mi' : '/en#about'
const contactUrl = locale === 'es' ? '#contacto' : '/en#contact'
---

<footer class="mx-auto mt-16 w-full max-w-[1200px] px-4">
  <hr class="section-divider opacity-60" />

  <div class="flex flex-col gap-3 py-6 text-sm md:flex-row md:items-center md:justify-between">
   <div class="text-[hsl(var(--caption-color))]">
       <span>&copy; {currentYear} &middot; </span>
       <a href="/" class="font-medium text-foreground hover:text-[hsl(var(--primary))] transition-colors focus-ring rounded">{personalInfo.name}</a>
     </div>

    <div class="flex items-center gap-4">
      <span class="text-xs text-[hsl(var(--caption-color))]">
        {t.footer.madeWith}
        <a href="https://astro.build" target="_blank" rel="noopener noreferrer" class="text-[hsl(var(--primary))] hover:underline focus-ring rounded">Astro</a>
        +
        <a href="https://tailwindcss.com" target="_blank" rel="noopener noreferrer" class="text-[hsl(var(--primary))] hover:underline focus-ring rounded">Tailwind</a>
      </span>

      <span class="text-[hsl(var(--caption-color))]/30" aria-hidden="true">&middot;</span>

      <nav aria-label={locale === 'es' ? 'Enlaces del pie' : 'Footer links'}>
        <ul class="flex items-center gap-4">
          <li>
            <a href={aboutUrl} class="text-[hsl(var(--caption-color))] hover:text-foreground transition-colors focus-ring rounded">{t.nav.about}</a>
          </li>
          <li>
            <a href={contactUrl} class="text-[hsl(var(--caption-color))] hover:text-foreground transition-colors focus-ring rounded">{t.nav.contact}</a>
          </li>
        </ul>
      </nav>
    </div>
  </div>
</footer>
