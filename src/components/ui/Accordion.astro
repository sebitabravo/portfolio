---
import { cn } from "@/lib/utils"

interface Props {
  title: string
  open?: boolean
  class?: string
}

const { title, open = false, class: className } = Astro.props
---

<details class={cn("group rounded-lg border border-border bg-card p-4", className)} open={open}>
  <summary class="cursor-pointer list-none text-sm font-semibold text-foreground marker:content-none">
    <span class="inline-flex items-center gap-2">
      <span class="transition-transform group-open:rotate-90">›</span>
      {title}
    </span>
  </summary>
  <div class="mt-3 text-sm text-foreground/85">
    <slot />
  </div>
</details>
