---
/**
 * Sebastian Bravo - Frontend Developer (English Version)
 *
 * Superhuman-inspired landing:
 * Hero → Projects → Experience → Education → Certs → About → Contact
 */
import Layout from "@/layouts/Layout.astro"
import { personalInfo } from "@/lib/data"
import { getTranslations } from "@/lib/i18n"

const t = getTranslations('en')

// Components
import Hero from "@/components/Hero.astro"
import Experience from "@/components/Experience.astro"
import Projects from "@/components/Projects.astro"
import Education from "@/components/Education.astro"
import Certifications from "@/components/Certifications.astro"
import AboutMe from "@/components/AboutMe.astro"
import Contact from "@/components/Contact.astro"
import SectionContainer from "@/components/SectionContainer.astro"
import TitleSection from "@/components/TitleSection.astro"

// Icons
import BriefcaseIcon from "@/components/icons/Briefcase.astro"
import CodeIcon from "@/components/icons/Code.astro"
import GraduationCapIcon from "@/components/icons/GraduationCap.astro"
import CertificateIcon from "@/components/icons/Certificate.astro"
import ProfileCheckIcon from "@/components/icons/ProfileCheck.astro"
import MailIcon from "@/components/icons/Mail.astro"
---

<Layout
  title={`${personalInfo.name} — ${personalInfo.title}`}
  description={personalInfo.description}
  locale="en"
>
  <main id="main-content">
  <Hero locale="en" />

  <div class="px-4 md:px-6">
    <div class="space-y-20 md:space-y-28 pt-16 md:pt-24">
      <!-- Projects -->
      <SectionContainer id="projects">
        <TitleSection>
          <CodeIcon class="size-6" />
          {t.projects.title}
        </TitleSection>
        <Projects locale="en" />
      </SectionContainer>

      <hr class="section-divider max-w-[1200px] mx-auto" />

      <!-- Education -->
      <SectionContainer id="education">
        <TitleSection>
          <GraduationCapIcon class="size-6" />
          {t.education.title}
        </TitleSection>
        <Education locale="en" />
      </SectionContainer>

      <hr class="section-divider max-w-[1200px] mx-auto" />

      <!-- Experience -->
      <SectionContainer id="experience">
        <TitleSection>
          <BriefcaseIcon class="size-6" />
          {t.work.title}
        </TitleSection>
        <Experience locale="en" />
      </SectionContainer>

      <hr class="section-divider max-w-[1200px] mx-auto" />

      <!-- Certifications -->
      <SectionContainer id="certifications" data-animate>
        <TitleSection>
          <CertificateIcon class="size-6" />
          {t.certifications.title}
        </TitleSection>
        <Certifications locale="en" />
      </SectionContainer>

      <hr class="section-divider max-w-[1200px] mx-auto" />

      <!-- About -->
      <SectionContainer id="about">
        <TitleSection>
          <ProfileCheckIcon class="size-6" />
          {t.about.title}
        </TitleSection>
        <AboutMe locale="en" />
      </SectionContainer>

      <hr class="section-divider max-w-[1200px] mx-auto" />

      <!-- Contact -->
      <SectionContainer id="contact">
        <TitleSection>
          <MailIcon class="size-6" />
          {t.contactForm.title}
        </TitleSection>
        <Contact locale="en" />
      </SectionContainer>
    </div>
  </div>
  </main>
</Layout>
