---
/**
 * CertificationCarousel Component
 *
 * Auto-scrolling carousel showing all certifications with logos and names.
 * Features:
 * - Infinite scroll animation
 * - Floating animation (up and down)
 * - Clickable to view PDF certificate
 * - Responsive design
 */
import type { CarouselCertification } from "@/types"
import type { Locale } from "@/lib/i18n"

interface Props {
  certifications: CarouselCertification[]
  locale?: Locale
}

const { certifications, locale = 'es' } = Astro.props

// Duplicate the array for seamless infinite scroll
const duplicatedCerts = [...certifications, ...certifications]
---

<div class="cert-carousel-container" id="certCarouselContainer">
  <button class="cert-nav-btn cert-nav-prev" id="certNavPrev" aria-label={locale === 'es' ? "Anterior" : "Previous"} type="button">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
  </button>

  <div class="cert-carousel-wrapper" id="certCarouselWrapper">
    <div class="cert-carousel" id="certCarousel">
      {duplicatedCerts.map((cert, index) => {
        const { name, organization, logo, pdfUrl, category } = cert.data
        const isDuplicate = index >= certifications.length

        return (
          <a
            href={pdfUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="cert-item"
            style={`animation-delay: ${(index % certifications.length) * 0.15}s`}
            title={`${name} - ${organization}`}
            aria-hidden={isDuplicate ? "true" : undefined}
            tabindex={isDuplicate ? "-1" : undefined}
            data-duplicate={isDuplicate ? "true" : undefined}
          >
            {logo ? (
              <div class="cert-logo-wrapper">
                <img src={logo} alt={organization} class="cert-logo" />
              </div>
            ) : (
              <div class="cert-placeholder">
                <svg class="cert-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                </svg>
              </div>
            )}
            <span class="cert-name">{name}</span>
            <span class="cert-org">{organization}</span>
            {category === 'professional' && (
              <span class="cert-badge cert-badge-pro">{locale === 'es' ? 'Profesional' : 'Professional'}</span>
            )}
            {category === 'academic' && (
              <span class="cert-badge cert-badge-acad">{locale === 'es' ? 'Académico' : 'Academic'}</span>
            )}
          </a>
        )
      })}
    </div>
  </div>

  <button class="cert-nav-btn cert-nav-next" id="certNavNext" aria-label={locale === 'es' ? "Siguiente" : "Next"} type="button">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
  </button>
</div>

<style>
  .cert-carousel-container {
    width: 100%;
    overflow: hidden;
    position: relative;
    padding: 2rem 0;

    /* Gradient masks for smooth fade */
    -webkit-mask-image: linear-gradient(
      to right,
      transparent,
      black 10%,
      black 90%,
      transparent
    );
    mask-image: linear-gradient(
      to right,
      transparent,
      black 10%,
      black 90%,
      transparent
    );
  }

  .cert-carousel-wrapper {
    overflow-x: auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .cert-carousel-wrapper::-webkit-scrollbar {
    display: none;
  }

  .cert-carousel {
    display: flex;
    gap: 2rem;
    width: fit-content;
  }

  .cert-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    min-width: 160px;
    max-width: 200px;
    padding: 1.5rem 1rem;
    background: hsl(var(--card));
    border: 1px solid hsl(var(--border));
    border-radius: 1rem;
    transition: all 0.3s ease;
    outline: none;
    animation: float 4s ease-in-out infinite;
    text-decoration: none;
    cursor: pointer;
  }

  .cert-item:hover {
    transform: translateY(-6px) scale(1.03);
    border-color: hsl(var(--primary));
    box-shadow: 0 10px 30px -10px hsl(var(--primary) / 0.3);
  }

  .cert-item:focus-visible {
    outline: 2px solid hsl(var(--primary));
    outline-offset: 2px;
    border-color: hsl(var(--primary));
  }

  .cert-logo-wrapper {
    width: 80px;
    height: 80px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 0.5rem;
    background: hsl(var(--background));
    padding: 0.5rem;
    transition: transform 0.3s ease;
  }

  .cert-logo {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .cert-placeholder {
    width: 80px;
    height: 80px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 0.5rem;
    background: linear-gradient(135deg, hsl(var(--primary) / 0.1), hsl(var(--secondary) / 0.1));
    transition: transform 0.3s ease;
  }

  .cert-icon {
    width: 48px;
    height: 48px;
    color: hsl(var(--primary));
  }

  .cert-item:hover .cert-logo-wrapper,
  .cert-item:hover .cert-placeholder {
    transform: scale(1.1) rotate(2deg);
  }

  .cert-name {
    font-size: 0.875rem;
    font-weight: 600;
    text-align: center;
    color: hsl(var(--foreground));
    line-height: 1.3;
  }

  .cert-org {
    font-size: 0.75rem;
    font-weight: 500;
    text-align: center;
    color: hsl(var(--muted-foreground));
    line-height: 1.2;
  }

  .cert-badge {
    font-size: 0.65rem;
    font-weight: 600;
    padding: 0.15rem 0.5rem;
    border-radius: 9999px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .cert-badge-pro {
    background: hsl(144 37% 45% / 0.12);
    color: hsl(144 37% 45%);
    border: 1px solid hsl(144 37% 45% / 0.25);
  }

  .cert-badge-acad {
    background: hsl(var(--muted));
    color: hsl(var(--muted-foreground));
    border: 1px solid hsl(var(--border));
  }

  /* Floating animation */
  @keyframes float {
    0%, 100% {
      transform: translateY(0px);
    }
    50% {
      transform: translateY(-6px);
    }
  }

  /* Navigation buttons — hidden until hover */
  .cert-nav-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 1px solid hsl(var(--border));
    background: hsl(var(--card) / 0.92);
    color: hsl(var(--foreground));
    cursor: pointer;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease, background 0.2s ease, transform 0.2s ease;
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
  }

  .cert-nav-btn:focus-visible {
    outline: 2px solid hsl(var(--primary));
    outline-offset: 2px;
  }

  .cert-nav-btn:hover {
    background: hsl(var(--card));
    border-color: hsl(var(--primary));
    color: hsl(var(--primary));
  }

  .cert-nav-prev {
    left: 8px;
  }

  .cert-nav-next {
    right: 8px;
  }

  .cert-carousel-container:hover .cert-nav-btn {
    opacity: 1;
    pointer-events: auto;
  }

  .cert-nav-btn:active {
    transform: translateY(-50%) scale(0.92);
  }

  /* Responsive adjustments */
  @media (max-width: 768px) {
    .cert-carousel {
      gap: 1.5rem;
    }

    .cert-item {
      min-width: 140px;
      max-width: 160px;
      padding: 1rem 0.75rem;
    }

    .cert-logo-wrapper,
    .cert-placeholder {
      width: 64px;
      height: 64px;
    }

    .cert-icon {
      width: 40px;
      height: 40px;
    }

    .cert-name {
      font-size: 0.8rem;
    }

    .cert-org {
      font-size: 0.7rem;
    }
  }

  /* Reduced motion: grid estático con todas las certificaciones */
  @media (prefers-reduced-motion: reduce) {
    .cert-carousel-container {
      overflow: visible;
      -webkit-mask-image: none;
      mask-image: none;
    }

    .cert-carousel-wrapper {
      overflow: visible;
      width: 100%;
    }

    .cert-carousel {
      flex-wrap: wrap;
      justify-content: center;
      gap: 1rem;
    }

    .cert-item {
      animation: none;
      min-width: 140px;
    }

    .cert-item[data-duplicate="true"] {
      display: none;
    }

    .cert-nav-btn {
      display: none;
    }
  }
</style>

<script>
  function initCertCarousel() {
    const container = document.getElementById('certCarouselContainer')
    const wrapper = document.getElementById('certCarouselWrapper')
    const carousel = document.getElementById('certCarousel')
    const prevBtn = document.getElementById('certNavPrev')
    const nextBtn = document.getElementById('certNavNext')

    if (!container || !wrapper || !carousel || !prevBtn || !nextBtn) return

    // Check reduced motion
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return

    let scrollInterval: ReturnType<typeof setInterval> | null = null
    const scrollSpeed = 1 // px per tick
    const tickMs = 25 // ~40fps smooth
    const navScrollAmount = 350 // px per arrow click

    function isHovered() {
      return container!.matches(':hover')
    }

    function startAutoScroll() {
      if (scrollInterval) return
      scrollInterval = setInterval(() => {
        if (isHovered()) return
        const w = wrapper!
        w.scrollLeft += scrollSpeed
        const halfWidth = w.scrollWidth / 2
        if (w.scrollLeft >= halfWidth) {
          w.scrollLeft = 0
        }
      }, tickMs)
    }

    function stopAutoScroll() {
      if (scrollInterval) {
        clearInterval(scrollInterval)
        scrollInterval = null
      }
    }

    // Arrow navigation
    prevBtn.addEventListener('click', () => {
      wrapper!.scrollBy({ left: -navScrollAmount, behavior: 'smooth' })
    })

    nextBtn.addEventListener('click', () => {
      const w = wrapper!
      w.scrollBy({ left: navScrollAmount, behavior: 'smooth' })
      const halfWidth = w.scrollWidth / 2
      if (w.scrollLeft + navScrollAmount >= halfWidth) {
        setTimeout(() => {
          w.scrollLeft = w.scrollLeft - halfWidth
        }, 350)
      }
    })

    // Pause on hover, resume on leave
    container.addEventListener('mouseenter', stopAutoScroll)
    container.addEventListener('mouseleave', startAutoScroll)

    // Start
    startAutoScroll()
  }

  document.addEventListener('DOMContentLoaded', initCertCarousel)
  document.addEventListener('astro:page-load', initCertCarousel)
</script>
