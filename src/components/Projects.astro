---
import { getProjects } from "@/lib/data"
import { getTranslations, type Locale } from "@/lib/i18n"
import { getTechStyle } from "@/lib/tech-colors"
import { getTechIcon } from "@/lib/tech-icons-map"
import GitHubIcon from "./icons/GitHub.astro"
import LinkIcon from "./icons/Link.astro"

interface Props {
  locale?: Locale
}

const { locale = "es" } = Astro.props
const t = getTranslations(locale)

const projects = getProjects(locale)
  .slice()
  .sort((projectA, projectB) => projectA.order - projectB.order)

const statusLabels: Record<string, Record<string, string>> = {
  es: { production: "En producción", development: "En desarrollo", demo: "Demo" },
  en: { production: "In production", development: "In development", demo: "Demo" },
}

const statusColors: Record<string, string> = {
  production: "bg-emerald-500/85 text-white border-emerald-400/30",
  development: "bg-amber-500/85 text-white border-amber-400/30",
  demo: "bg-sky-500/85 text-white border-sky-400/30",
}

const visualGradients: Record<string, string> = {
  manttoai: "linear-gradient(140deg, #0e5f66 0%, #3d9f7a 100%)",
  vulcania: "linear-gradient(140deg, #7a2a0a 0%, #e35b25 45%, #f3aa3a 100%)",
  "rapido-sur": "linear-gradient(140deg, #1e3a8a 0%, #3730a3 50%, #6d28d9 100%)",
  wenuke: "linear-gradient(140deg, #075e54 0%, #128c7e 50%, #25d366 100%)",
}

---

<div class="space-y-12">
  <div class="grid gap-6 sm:gap-8 md:grid-cols-2" data-projects-list>
    {projects.map(({ slug, title, description, tags, liveUrl, githubUrl, featured, status, metrics }, i) => {
      const statusLabel = status ? statusLabels[locale]?.[status] : undefined
      const statusColor = status ? statusColors[status] : ""
      const gradient = visualGradients[slug] ?? "linear-gradient(140deg, #2b2b2b 0%, #5a5a5a 100%)"

      const maxTags = 4
      const visibleTags = tags.slice(0, maxTags)
      const visualStats = metrics?.length ? metrics.slice(0, 2) : visibleTags.slice(0, 2).map((tag) => ({ label: "Stack", value: tag }))

      return (
        <article
          data-animate
          data-animate-delay={String((i % 4) + 1)}
          class="group flex h-full flex-col overflow-hidden rounded-2xl border border-[hsl(var(--parchment))] bg-[hsl(var(--card))] transition-all duration-300 hover:-translate-y-[2px] hover:shadow-[var(--shadow-card-hover)]"
          data-project-card
          data-project={slug}
          data-project-tags={tags.join(",")}
        >
          <div class="relative overflow-hidden border-b border-[hsl(var(--parchment))]">
            <div class="relative aspect-[16/10] w-full" style={`background:${gradient};`}>
              <div class="absolute inset-0 bg-black/15"></div>
              <div class="absolute inset-0 bg-[radial-gradient(circle_at_20%_20%,rgba(255,255,255,0.18),transparent_28%),linear-gradient(rgba(255,255,255,0.08)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.08)_1px,transparent_1px)] bg-[length:100%_100%,28px_28px,28px_28px]"></div>
              <div class="absolute right-3 top-3 flex max-w-[58%] flex-col gap-2 sm:right-4 sm:top-4">
                {visualStats.map((metric) => (
                  <div class="rounded-lg border border-white/20 bg-white/12 px-3 py-2 text-right shadow-sm backdrop-blur-sm">
                    <span class="block text-[10px] font-mono uppercase tracking-[0.14em] !text-white/65">{metric.label}</span>
                    <span class="block text-xs font-semibold !text-white sm:text-sm">{metric.value}</span>
                  </div>
                ))}
              </div>
              <div class="absolute inset-x-0 bottom-0 p-3 sm:p-4 lg:p-5">
                {statusLabel && (
                  <span class:list={["inline-block rounded-md border px-2 py-0.5 text-[10px] font-mono uppercase tracking-[0.14em] mb-1.5", statusColor]}>
                    {statusLabel}
                  </span>
                )}
                <div class="flex flex-wrap items-end justify-between gap-2">
                  <h3 class="mt-1 font-mono text-lg font-semibold !text-white drop-shadow-sm sm:text-xl lg:text-2xl">{title}</h3>
                  {featured && (
                    <span class="rounded-md border border-white/30 bg-white/15 px-2 py-0.5 text-[10px] font-mono uppercase tracking-[0.12em] !text-white/90">
                      {t.projects.featured}
                    </span>
                  )}
                </div>
              </div>
            </div>
          </div>

          <div class="flex grow flex-col p-4 sm:p-5 lg:p-6">

            <p class="text-sm leading-[1.60] text-foreground/75 sm:text-base line-clamp-3 min-h-[4.2rem] sm:min-h-[4.8rem]">{description}</p>

            <div class="mt-5 w-full">
              <div class="flex flex-wrap gap-2">
                {visibleTags.map((tag) => {
                  const style = getTechStyle(tag)
                  const Icon = getTechIcon(tag)

                  return (
                    <span class:list={["tech-badge flex items-center gap-1.5", style.bg, style.border, style.text]}>
                      {Icon && <Icon class="size-3 sm:size-4" />}
                      {tag}
                    </span>
                  )
                })}


              </div>

              <footer class="mt-4 flex flex-wrap items-center gap-2">
                {githubUrl && (
                  <a
                    href={githubUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    data-track-project={slug}
                    data-track-action="code"
                    class="inline-flex h-11 items-center gap-1.5 sm:gap-2 rounded-lg border border-[hsl(var(--parchment))] bg-transparent px-3 sm:px-3.5 text-sm font-medium text-foreground/85 transition hover:bg-[hsl(var(--muted))]"
                  >
                    <GitHubIcon class="size-3 sm:size-4" />
                    {t.projects.viewCode}
                  </a>
                )}

                {liveUrl && (
                  <a
                    href={liveUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    data-track-project={slug}
                    data-track-action="live"
                    class="btn-cream !h-11 !px-3 sm:!px-3.5 !text-sm"
                  >
                    <LinkIcon class="size-3 sm:size-4" />
                    {t.projects.viewProject}
                  </a>
                )}
              </footer>
            </div>
          </div>
        </article>
      )
    })}
  </div>

  <div class="mt-4 flex justify-center">
    <a
      href="https://github.com/sebitabravo?tab=repositories"
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex h-11 items-center gap-2 rounded-lg border border-[hsl(var(--parchment))] bg-transparent px-4 text-sm font-medium text-foreground/85 transition hover:bg-[hsl(var(--muted))]"
    >
      <GitHubIcon class="size-4" />
      {t.projects.viewMoreGithub}
      <svg class="ml-1 size-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
      </svg>
    </a>
  </div>
</div>

<script>
  import { trackEvent } from "@/lib/analytics"

  const setupProjects = () => {
    const trackButtons = document.querySelectorAll<HTMLElement>("[data-track-project]")
    trackButtons.forEach((btn) => {
      if (btn.dataset.trackBound === "true") return
      btn.dataset.trackBound = "true"
      btn.addEventListener("click", () => {
        const project = btn.dataset.trackProject ?? ""
        const action = (btn.dataset.trackAction ?? "code") as "live" | "code"
        trackEvent({ name: "project_view", props: { project, action } })
      })
    })



  }

  document.addEventListener("astro:page-load", setupProjects)
  setupProjects()
</script>
