---
interface Props {
  id: string
}

const { id } = Astro.props
---

<div
  id={id}
  class="pointer-events-none fixed bottom-6 right-4 z-[60] max-w-sm rounded-lg border border-border bg-card px-4 py-3 text-sm text-card-foreground opacity-0 shadow-lg transition-all duration-300"
  data-toast
  role="status"
  aria-live="polite"
>
  <p data-toast-message></p>
</div>

<script>
  if (!window.portfolioToast) {
    window.portfolioToast = {
      show(id: string, message: string, type: "success" | "error" = "success") {
        const toast = document.getElementById(id)
        if (!(toast instanceof HTMLElement)) return

        const messageElement = toast.querySelector("[data-toast-message]")
        if (messageElement instanceof HTMLElement) {
          messageElement.textContent = message
        }

        toast.classList.remove("opacity-0", "translate-y-2", "border-red-500/40", "border-emerald-500/40")
        toast.classList.add("opacity-100", "translate-y-0")

        if (type === "error") {
          toast.classList.add("border-red-500/40")
        } else {
          toast.classList.add("border-emerald-500/40")
        }

        const currentTimeout = toast.dataset.hideTimeout
        if (currentTimeout) {
          window.clearTimeout(Number(currentTimeout))
        }

        const timeoutId = window.setTimeout(() => {
          toast.classList.remove("opacity-100", "translate-y-0")
          toast.classList.add("opacity-0", "translate-y-2")
        }, 4000)

        toast.dataset.hideTimeout = String(timeoutId)
      },
    }
  }
</script>
