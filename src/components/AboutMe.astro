---
// About Me — Superhuman clean layout
import { Image } from "astro:assets"
import { getAboutMe } from "@/lib/data"
import type { Locale } from "@/lib/i18n"
import profileImage from "@/assets/perfil.jpeg"
import TechCarousel from "@/components/TechCarousel.astro"

interface Props {
  locale?: Locale
}

const { locale = 'es' } = Astro.props
const aboutMe = getAboutMe(locale)

const specialties = locale === 'es'
  ? [
      "Desarrollo de interfaces con React y TypeScript",
      "Diseño e implementación de componentes accesibles (WCAG)",
      "Optimización de performance web (Core Web Vitals)",
      "Integración de APIs REST",
      "Desarrollo con Astro y Next.js",
      "Estilado con Tailwind CSS y CSS moderno",
    ]
  : [
      "Interface development with React and TypeScript",
      "Accessible component design (WCAG)",
      "Web performance optimization (Core Web Vitals)",
      "REST API integration",
      "Development with Astro and Next.js",
      "Styling with Tailwind CSS and modern CSS",
    ]
---

<div class="space-y-16">
  <article class="flex flex-col items-center gap-12 text-foreground/80 md:flex-row">
    <!-- Texto -->
    <div data-animate data-animate-delay="1" class="order-2 md:order-1 max-w-xl space-y-4">
      <p class="text-base leading-[1.60]">{aboutMe.intro}</p>
      <p class="text-base leading-[1.60]">{aboutMe.experience}</p>
      <p class="text-base leading-[1.60]">{aboutMe.personal}</p>

      <div class="pt-6">
        <h3 class="text-lg font-semibold mb-3 text-foreground">{aboutMe.interestsTitle}</h3>
        <ul class="space-y-1.5">
          {aboutMe.interests.map((interest) => (
            <li class="flex items-center gap-2 text-sm text-foreground/70">
              <span class="h-1 w-1 rounded-full bg-[hsl(var(--primary))]"></span>
              {interest}
            </li>
          ))}
        </ul>
      </div>

      <section aria-label={locale === 'es' ? "Competencias técnicas" : "Technical competencies"} class="mt-6 pt-6 border-t border-[hsl(var(--parchment))]">
        <h3 class="text-sm font-semibold text-foreground mb-3">{locale === 'es' ? "Especialidades" : "Specialties"}</h3>
        <ul class="grid grid-cols-1 sm:grid-cols-2 gap-1.5">
          {specialties.map((s) => (
            <li class="flex items-center gap-2 text-sm text-foreground/70">
              <span class="h-1.5 w-1.5 rounded-full bg-[hsl(var(--primary))] shrink-0" aria-hidden="true"></span>
              {s}
            </li>
          ))}
        </ul>
      </section>
    </div>

    <!-- Imagen -->
    <div data-animate data-animate-delay="2" class="order-1 md:order-2 shrink-0">
      <Image
        width={220}
        height={220}
        src={profileImage}
        alt="Sebastian Bravo"
        class="rounded-2xl object-cover aspect-square ring-1 ring-[hsl(var(--parchment))]"
        style="object-position: 50% 50%"
      />
    </div>
  </article>

  <!-- Tech Stack Dashboard -->
  <div class="mt-8">
    <h3 class="text-lg font-semibold mb-2 text-center text-foreground">
      {locale === 'es' ? "Mi Stack Tecnológico" : "My Tech Stack"}
    </h3>
    <p class="text-sm text-center text-[hsl(var(--caption-color))] mb-6">
      {locale === 'es' ? "Las herramientas con las que construyo día a día" : "The tools I build with day to day"}
    </p>
    <TechCarousel />
  </div>
</div>
