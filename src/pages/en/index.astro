---
/**
 * Portfolio de Sebastian Bravo - Full Stack Developer (English Version)
 *
 * Home reestructurada como landing de conversión:
 * Hero → Proyectos → Prueba social → CTA Contacto → Experiencia → Educación → Certs → Sobre mí
 *
 * Issues resueltas: #11 (estructura landing), #13 (logos clientes), #14 (interactividad conversión)
 */
import Layout from "@/layouts/Layout.astro"
import { personalInfo } from "@/lib/data"
import { getTranslations } from "@/lib/i18n"

const t = getTranslations('en')

// Components
import Hero from "@/components/Hero.astro"
import Experience from "@/components/Experience.astro"
import Projects from "@/components/Projects.astro"
import Education from "@/components/Education.astro"
import Certifications from "@/components/Certifications.astro"
import AboutMe from "@/components/AboutMe.astro"
import ContactForm from "@/components/ContactForm.astro"
import SectionContainer from "@/components/SectionContainer.astro"
import TitleSection from "@/components/TitleSection.astro"

// Icons
import BriefcaseIcon from "@/components/icons/Briefcase.astro"
import CodeIcon from "@/components/icons/Code.astro"
import GraduationCapIcon from "@/components/icons/GraduationCap.astro"
import CertificateIcon from "@/components/icons/Certificate.astro"
import ProfileCheckIcon from "@/components/icons/ProfileCheck.astro"
import MailIcon from "@/components/icons/Mail.astro"
---

<Layout
  title={`Portfolio - ${personalInfo.name} | ${personalInfo.title}`}
  description={personalInfo.description}
  locale="en"
>
  <main class="px-4">
    <!-- Hero: value proposition + main CTA -->
    <SectionContainer class="py-16 md:py-36">
      <Hero locale="en" />
    </SectionContainer>

    <div class="space-y-24">
      <!-- Projects: concrete evidence of work — first scroll -->
      <SectionContainer id="projects">
        <TitleSection>
          <CodeIcon class="size-7" />
          {t.projects.title}
        </TitleSection>
        <Projects locale="en" />
      </SectionContainer>

      <!-- Contact CTA: main conversion action -->
      <SectionContainer id="contact">
        <TitleSection>
          <MailIcon class="size-8" />
          {t.contactForm.title}
        </TitleSection>
        <ContactForm locale="en" />
      </SectionContainer>

      <!-- Curriculum content: reinforces credibility -->
      <SectionContainer id="experience">
        <TitleSection>
          <BriefcaseIcon class="size-8" />
          {t.work.title}
        </TitleSection>
        <Experience locale="en" />
      </SectionContainer>

      <SectionContainer id="education">
        <TitleSection>
          <GraduationCapIcon class="size-8" />
          {t.education.title}
        </TitleSection>
        <Education locale="en" />
      </SectionContainer>

      <SectionContainer id="certifications">
        <TitleSection>
          <CertificateIcon class="size-8" />
          {t.certifications.title}
        </TitleSection>
        <Certifications locale="en" />
      </SectionContainer>

      <SectionContainer id="about">
        <TitleSection>
          <ProfileCheckIcon class="size-8" />
          {t.about.title}
        </TitleSection>
        <AboutMe locale="en" />
      </SectionContainer>
    </div>
  </main>
</Layout>
