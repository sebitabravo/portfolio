---
/**
 * Portfolio de Sebastian Bravo - Frontend Developer
 *
 * Landing de conversión con estética Superhuman:
 * Hero → Proyectos → Experiencia → Educación → Certs → Sobre mí → Contacto
 */
import Layout from "@/layouts/Layout.astro"
import { personalInfo } from "@/lib/data"
import { getTranslations } from "@/lib/i18n"

const t = getTranslations('es')

// Components
import Hero from "@/components/Hero.astro"
import Experience from "@/components/Experience.astro"
import Projects from "@/components/Projects.astro"
import Education from "@/components/Education.astro"
import Certifications from "@/components/Certifications.astro"
import AboutMe from "@/components/AboutMe.astro"
import Contact from "@/components/Contact.astro"
import SectionContainer from "@/components/SectionContainer.astro"
import TitleSection from "@/components/TitleSection.astro"

// Icons
import BriefcaseIcon from "@/components/icons/Briefcase.astro"
import CodeIcon from "@/components/icons/Code.astro"
import GraduationCapIcon from "@/components/icons/GraduationCap.astro"
import CertificateIcon from "@/components/icons/Certificate.astro"
import ProfileCheckIcon from "@/components/icons/ProfileCheck.astro"
import MailIcon from "@/components/icons/Mail.astro"
---

<Layout
  title={`${personalInfo.name} — ${personalInfo.title}`}
  description={personalInfo.description}
  locale="es"
>
  <!-- Hero: midnight gradient, full-width -->
  <Hero locale="es" />

  <main class="px-4 md:px-6">
    <div class="space-y-20 md:space-y-28 pt-16 md:pt-24">
      <!-- Proyectos -->
      <SectionContainer id="proyectos">
        <TitleSection>
          <CodeIcon class="size-6" />
          Proyectos
        </TitleSection>
        <Projects locale="es" />
      </SectionContainer>

      <hr class="section-divider max-w-5xl mx-auto" />

      <!-- Experiencia -->
      <SectionContainer id="experiencia" data-animate>
        <TitleSection>
          <BriefcaseIcon class="size-6" />
          Experiencia Laboral
        </TitleSection>
        <Experience locale="es" />
      </SectionContainer>

      <hr class="section-divider max-w-5xl mx-auto" />

      <!-- Educaci&oacute;n -->
      <SectionContainer id="educacion" data-animate>
        <TitleSection>
          <GraduationCapIcon class="size-6" />
          Educaci&oacute;n
        </TitleSection>
        <Education locale="es" />
      </SectionContainer>

      <hr class="section-divider max-w-5xl mx-auto" />

      <!-- Certificaciones -->
      <SectionContainer id="certificaciones" data-animate>
        <TitleSection>
          <CertificateIcon class="size-6" />
          Certificaciones
        </TitleSection>
        <Certifications locale="es" />
      </SectionContainer>

      <hr class="section-divider max-w-5xl mx-auto" />

      <!-- Sobre m&iacute; -->
      <SectionContainer id="sobre-mi" data-animate>
        <TitleSection>
          <ProfileCheckIcon class="size-6" />
          Sobre m&iacute;
        </TitleSection>
        <AboutMe locale="es" />
      </SectionContainer>

      <hr class="section-divider max-w-5xl mx-auto" />

      <!-- Contacto -->
      <SectionContainer id="contacto" data-animate>
        <TitleSection>
          <MailIcon class="size-6" />
          {t.contactForm.title}
        </TitleSection>
        <Contact locale="es" />
      </SectionContainer>
    </div>
  </main>
</Layout>
