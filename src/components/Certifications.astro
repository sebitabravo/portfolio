---
// Certifications Component
import { getCertifications } from "@/lib/data"
import type { Locale } from "@/lib/i18n"
import type { CarouselCertification } from "@/types"
import CertificationCarousel from "@/components/CertificationCarousel.astro"

interface Props {
  locale?: Locale
}

const { locale = 'es' } = Astro.props
const certifications = getCertifications(locale)

const certificationsForCarousel: CarouselCertification[] = certifications.map(cert => ({
  data: {
    name: cert.name,
    organization: cert.organization,
    logo: undefined,
    pdfUrl: cert.pdfUrl || '#'
  }
}))
---

<div>
   <CertificationCarousel certifications={certificationsForCarousel} />
 </div>
