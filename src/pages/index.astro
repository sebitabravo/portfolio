---
/**
 * Portfolio de Sebastian Bravo - Desarrollador Full Stack
 *
 * Home reestructurada como landing de conversión:
 * Hero → Proyectos → Experiencia → Educación → Certs → Sobre mí → Contacto
 *
 * Issues resueltas: #11 (estructura landing), #14 (interactividad conversión)
 * Pendiente: #13 (logos clientes — requiere assets reales de empresas)
 */
import Layout from "@/layouts/Layout.astro"
import { personalInfo } from "@/lib/data"
import { getTranslations } from "@/lib/i18n"

const t = getTranslations('es')

// Components
import Hero from "@/components/Hero.astro"
import Experience from "@/components/Experience.astro"
import Projects from "@/components/Projects.astro"
import Education from "@/components/Education.astro"
import Certifications from "@/components/Certifications.astro"
import AboutMe from "@/components/AboutMe.astro"
import ContactForm from "@/components/ContactForm.astro"
import SectionContainer from "@/components/SectionContainer.astro"
import TitleSection from "@/components/TitleSection.astro"

// Icons
import BriefcaseIcon from "@/components/icons/Briefcase.astro"
import CodeIcon from "@/components/icons/Code.astro"
import GraduationCapIcon from "@/components/icons/GraduationCap.astro"
import CertificateIcon from "@/components/icons/Certificate.astro"
import ProfileCheckIcon from "@/components/icons/ProfileCheck.astro"
import MailIcon from "@/components/icons/Mail.astro"
---

<Layout
  title={`Portfolio - ${personalInfo.name} | ${personalInfo.title}`}
  description={personalInfo.description}
  locale="es"
>
  <main class="px-4">
    <!-- Hero: propuesta de valor + CTA principal -->
    <SectionContainer class="py-16 md:py-36">
      <Hero locale="es" />
    </SectionContainer>

    <div class="space-y-24">
      <!-- Proyectos: evidencia concreta del trabajo — primer scroll -->
      <SectionContainer id="proyectos">
        <TitleSection>
          <CodeIcon class="size-7" />
          Proyectos
        </TitleSection>
        <Projects locale="es" />
      </SectionContainer>

      <!-- Contenido curricular: refuerza credibilidad -->
      <SectionContainer id="experiencia">
        <TitleSection>
          <BriefcaseIcon class="size-8" />
          Experiencia Laboral
        </TitleSection>
        <Experience locale="es" />
      </SectionContainer>

      <SectionContainer id="educacion">
        <TitleSection>
          <GraduationCapIcon class="size-8" />
          Educación
        </TitleSection>
        <Education locale="es" />
      </SectionContainer>

      <SectionContainer id="certificaciones">
        <TitleSection>
          <CertificateIcon class="size-8" />
          Certificaciones
        </TitleSection>
        <Certifications locale="es" />
      </SectionContainer>

      <SectionContainer id="sobre-mi">
        <TitleSection>
          <ProfileCheckIcon class="size-8" />
          Sobre mí
        </TitleSection>
        <AboutMe locale="es" />
      </SectionContainer>

      <!-- Contacto: al final, después de toda la credibilidad -->
      <SectionContainer id="contacto">
        <TitleSection>
          <MailIcon class="size-8" />
          {t.contactForm.title}
        </TitleSection>
        <ContactForm locale="es" />
      </SectionContainer>
    </div>
  </main>
</Layout>
