---
import { cn } from "@/lib/utils"

interface TabOption {
  value: string
  label: string
}

interface Props {
  id: string
  options: TabOption[]
  defaultValue?: string
  class?: string
}

const { id, options, defaultValue = "all", class: className } = Astro.props
---

<div
  id={id}
  class={cn("inline-flex flex-wrap items-center justify-center gap-2 rounded-xl border border-border bg-card/70 p-2", className)}
  role="tablist"
  data-tabs-root
  data-tabs-value={defaultValue}
>
  {options.map((option) => {
    const isActive = option.value === defaultValue
    return (
      <button
        type="button"
        role="tab"
        aria-selected={isActive}
        data-tab-value={option.value}
        class:list={[
          "rounded-md px-3 py-1.5 text-xs font-medium transition-colors focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring md:text-sm",
          isActive
            ? "bg-primary text-primary-foreground shadow"
            : "text-muted-foreground hover:bg-accent hover:text-accent-foreground",
        ]}
      >
        {option.label}
      </button>
    )
  })}
</div>

<script>
  if (!window.__portfolioTabsBound) {
    window.__portfolioTabsBound = true

    document.addEventListener("click", (event) => {
      const target = event.target
      if (!(target instanceof Element)) return

      const tabButton = target.closest("[data-tab-value]")
      if (!(tabButton instanceof HTMLButtonElement)) return

      const tabsRoot = tabButton.closest("[data-tabs-root]")
      if (!(tabsRoot instanceof HTMLElement)) return

      const tabValue = tabButton.dataset.tabValue
      if (!tabValue) return

      tabsRoot.dataset.tabsValue = tabValue

      tabsRoot.querySelectorAll("[data-tab-value]").forEach((button) => {
        if (!(button instanceof HTMLButtonElement)) return

        const isActive = button.dataset.tabValue === tabValue
        button.setAttribute("aria-selected", String(isActive))
        button.classList.toggle("bg-primary", isActive)
        button.classList.toggle("text-primary-foreground", isActive)
        button.classList.toggle("shadow", isActive)
        button.classList.toggle("text-muted-foreground", !isActive)
        button.classList.toggle("hover:bg-accent", !isActive)
        button.classList.toggle("hover:text-accent-foreground", !isActive)
      })

      tabsRoot.dispatchEvent(new CustomEvent("tabs:change", { detail: { value: tabValue } }))
    })
  }
</script>
