---
// Hero Component - Main hero section
import { Image } from "astro:assets"
import { personalInfo, social } from "@/lib/data"
import { getTranslations, type Locale } from "@/lib/i18n"
import profileImage from "@/assets/perfil.jpeg"
import AvailableBadge from "./AvailableBadge.astro"
import SocialPill from "./SocialPill.astro"
import GitHubIcon from "./icons/GitHub.astro"
import LinkedInIcon from "./icons/LinkedIn.astro"
import MailIcon from "./icons/Mail.astro"
import DownloadIcon from "./icons/Download.astro"
import cvPdf from "@/assets/Sebastian_Bravo_CV.pdf"

interface Props {
  locale?: Locale
}

const { locale = 'es' } = Astro.props
const t = getTranslations(locale)
const contactUrl = locale === 'es' ? '#contacto' : '/en#contact'
---

<div class="max-w-xl">
  <div class="flex gap-4 mb-4">
    <Image
      src={profileImage}
      alt={personalInfo.name}
      width={128}
      height={128}
      format="webp"
      quality={90}
      class="size-16 rounded-full object-cover shadow-lg"
    />
    {personalInfo.available && (
      <a
        href={social.linkedin}
        target="_blank"
        rel="noopener"
        class="flex items-center transition md:justify-center md:hover:scale-105"
      >
        <AvailableBadge>{t.hero.available}</AvailableBadge>
      </a>
    )}
  </div>

  <h1 class="text-4xl font-bold tracking-tight sm:text-5xl text-foreground">
    {t.hero.greeting} {personalInfo.name}
  </h1>

  <p class="mt-6 text-xl text-foreground/80">
    {t.hero.intro}
  </p>

  <nav class="flex flex-wrap gap-3 mt-8">
    <!-- CTA principal: mayor peso visual para guiar la conversión -->
    <a
      href={contactUrl}
      class="cta-primary inline-flex items-center gap-2 rounded-full bg-primary px-5 py-2.5 text-sm font-semibold text-primary-foreground shadow-sm transition-all duration-200 hover:bg-primary/90 hover:shadow-md focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 active:scale-95"
    >
      <MailIcon class="size-4" />
      {t.hero.contact}
    </a>

    <!-- CTAs secundarios: menor peso visual -->
    <SocialPill href={social.linkedin} target="_blank" rel="noopener" data-track-social="linkedin">
      <LinkedInIcon class="size-4" />
      LinkedIn
    </SocialPill>
    <SocialPill href={social.github} target="_blank" rel="noopener" data-track-social="github">
      <GitHubIcon class="size-4" />
      GitHub
    </SocialPill>
    <SocialPill href={cvPdf} target="_blank" rel="noopener" data-track-cv={locale}>
      <DownloadIcon class="size-4" />
      {t.hero.downloadCv}
    </SocialPill>
  </nav>
</div>

<script>
  import { trackEvent } from "@/lib/analytics"

  const setupHeroTracking = () => {
    // Tracking de social pills
    document.querySelectorAll<HTMLElement>("[data-track-social]").forEach((el) => {
      if (el.dataset.trackBound === "true") return
      el.dataset.trackBound = "true"
      el.addEventListener("click", () => {
        trackEvent({ name: "social_click", props: { platform: el.dataset.trackSocial ?? "" } })
      })
    })

    // Tracking de descarga de CV
    document.querySelectorAll<HTMLElement>("[data-track-cv]").forEach((el) => {
      if (el.dataset.trackBound === "true") return
      el.dataset.trackBound = "true"
      el.addEventListener("click", () => {
        trackEvent({ name: "cv_download", props: { locale: el.dataset.trackCv ?? "" } })
      })
    })
  }

  document.addEventListener("astro:page-load", setupHeroTracking)
  setupHeroTracking()
</script>
