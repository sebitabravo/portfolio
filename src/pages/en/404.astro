---
import Layout from "@/layouts/Layout.astro"
import Button from "@/components/ui/Button.astro"
import { personalInfo } from "@/lib/data"
---

<Layout
  title={`404 | ${personalInfo.name}`}
  description="The page you requested does not exist."
  locale="en"
  noindex
>
  <main class="mx-auto flex min-h-[60vh] max-w-2xl flex-col items-center justify-center gap-6 px-4 text-center">
    <p class="text-sm font-semibold uppercase tracking-[0.2em] text-muted-foreground">Error 404</p>
    <h1 class="text-4xl font-bold text-foreground md:text-5xl">This page got lost in deployment</h1>
    <p class="max-w-xl text-foreground/80">We could not find what you asked for. Jump back home and keep exploring.</p>
    <Button href="/en" variant="default" size="lg">Back to home</Button>
  </main>
</Layout>
