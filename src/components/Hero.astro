---
// Hero Component - Main hero section
import { Image } from "astro:assets"
import { personalInfo, social } from "@/lib/data"
import { getTranslations, type Locale } from "@/lib/i18n"
import profileImage from "@/assets/perfil.jpeg"
import AvailableBadge from "./AvailableBadge.astro"
import SocialPill from "./SocialPill.astro"
import GitHubIcon from "./icons/GitHub.astro"
import LinkedInIcon from "./icons/LinkedIn.astro"
import MailIcon from "./icons/Mail.astro"
import DownloadIcon from "./icons/Download.astro"
import cvPdf from "@/assets/Sebastian_Bravo_CV.pdf"

interface Props {
  locale?: Locale
}

const { locale = 'es' } = Astro.props
const t = getTranslations(locale)
---

<div class="max-w-xl">
  <div class="flex gap-4 mb-4">
    <Image
      class="rounded-full shadow-lg size-16"
      src={profileImage}
      width={64}
      height={64}
      alt={personalInfo.name}
    />
    {personalInfo.available && (
      <a
        href={social.linkedin}
        target="_blank"
        rel="noopener"
        class="flex items-center transition md:justify-center md:hover:scale-105"
      >
        <AvailableBadge>{t.hero.available}</AvailableBadge>
      </a>
    )}
  </div>

  <h1 class="text-4xl font-bold tracking-tight sm:text-5xl text-foreground">
    {t.hero.greeting} {personalInfo.name}
  </h1>

  <p class="mt-6 text-xl text-foreground/80">
    {t.hero.intro}
  </p>

  <nav class="flex flex-wrap gap-4 mt-8">
    <SocialPill href={`mailto:${personalInfo.email}`}>
      <MailIcon class="size-4" />
      {t.hero.contact}
    </SocialPill>
    <SocialPill href={social.linkedin} target="_blank" rel="noopener">
      <LinkedInIcon class="size-4" />
      LinkedIn
    </SocialPill>
    <SocialPill href={social.github} target="_blank" rel="noopener">
      <GitHubIcon class="size-4" />
      GitHub
    </SocialPill>
    <SocialPill href={cvPdf} target="_blank" rel="noopener">
      <DownloadIcon class="size-4" />
      {t.hero.downloadCv}
    </SocialPill>
  </nav>
</div>
